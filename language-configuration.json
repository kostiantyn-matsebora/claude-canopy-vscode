{
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([A-Z][A-Z0-9_]+)|([a-zA-Z_$][a-zA-Z0-9_$-]*)",
  "brackets": [
    ["`", "`"]
  ],
  "autoClosingPairs": [
    { "open": "`", "close": "`", "notIn": ["string"] },
    { "open": "<", "close": ">", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["`", "`"],
    ["<", ">"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^## ",
      "end": "^## "
    }
  }
}
