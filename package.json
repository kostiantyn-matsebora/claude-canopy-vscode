{
  "name": "canopy-skills",
  "displayName": "Canopy Skills",
  "description": "Write Claude Code AI skills as executable code, not prose — syntax highlighting, IntelliSense, semantic diagnostics, and go-to-definition for Canopy skills: skill.md, ops.md, schemas, templates, commands, constants, policies, checklists, and verify files.",
  "version": "0.5.0",
  "canopyVersion": "0.15.0",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0969da",
    "theme": "dark"
  },
  "publisher": "canopy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets",
    "AI"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kostiantyn-matsebora/claude-canopy-vscode"
  },
  "bugs": {
    "url": "https://github.com/kostiantyn-matsebora/claude-canopy-vscode/issues"
  },
  "homepage": "https://github.com/kostiantyn-matsebora/claude-canopy-vscode#readme",
  "keywords": [
    "canopy",
    "skill",
    "claude",
    "ai",
    "markdown"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "canopy",
        "aliases": [
          "Canopy Skill",
          "canopy"
        ],
        "filenamePatterns": [
          "**/.claude/**/skill.md",
          "**/.claude/**/ops.md",
          "**/.github/**/skill.md",
          "**/.github/**/ops.md"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "canopy-verify",
        "aliases": [
          "Canopy Verify",
          "canopy-verify"
        ],
        "filenamePatterns": [
          "**/.claude/**/verify/*.md",
          "**/.claude/**/checklists/*.md",
          "**/.github/**/verify/*.md",
          "**/.github/**/checklists/*.md"
        ]
      },
      {
        "id": "canopy-template",
        "aliases": [
          "Canopy Template",
          "canopy-template"
        ],
        "filenamePatterns": [
          "**/.claude/**/templates/*.md",
          "**/.claude/**/templates/*.yaml",
          "**/.github/**/templates/*.md",
          "**/.github/**/templates/*.yaml"
        ]
      },
      {
        "id": "canopy-resource",
        "aliases": [
          "Canopy Resource",
          "canopy-resource"
        ],
        "filenamePatterns": [
          "**/.claude/**/constants/*.md",
          "**/.claude/**/policies/*.md",
          "**/.claude/**/schemas/*.md",
          "**/.github/**/constants/*.md",
          "**/.github/**/policies/*.md",
          "**/.github/**/schemas/*.md"
        ]
      },
      {
        "id": "canopy-commands",
        "aliases": [
          "Canopy Commands",
          "canopy-commands"
        ],
        "filenamePatterns": [
          "**/.claude/**/commands/*.ps1",
          "**/.claude/**/commands/*.sh",
          "**/.github/**/commands/*.ps1",
          "**/.github/**/commands/*.sh"
        ]
      }
    ],
    "grammars": [
      {
        "language": "canopy",
        "scopeName": "text.canopy",
        "path": "./syntaxes/canopy.tmLanguage.json"
      },
      {
        "language": "canopy-verify",
        "scopeName": "text.canopy-verify",
        "path": "./syntaxes/canopy-verify.tmLanguage.json"
      },
      {
        "language": "canopy-template",
        "scopeName": "text.canopy-template",
        "path": "./syntaxes/canopy-template.tmLanguage.json"
      },
      {
        "language": "canopy-resource",
        "scopeName": "text.canopy-resource",
        "path": "./syntaxes/canopy-resource.tmLanguage.json"
      },
      {
        "language": "canopy-commands",
        "scopeName": "text.canopy-commands",
        "path": "./syntaxes/canopy-commands.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "canopy",
        "path": "./snippets/canopy.json"
      }
    ],
    "commands": [
      {
        "command": "canopy.showVersion",
        "title": "Show Version",
        "category": "Canopy"
      },
      {
        "command": "canopy.addAsSubmodule",
        "title": "Add as submodule",
        "category": "Canopy"
      },
      {
        "command": "canopy.addAsCopy",
        "title": "Add as copy (minimal files)",
        "category": "Canopy"
      },
      {
        "command": "canopy.newSkill",
        "title": "New Skill",
        "category": "Canopy"
      },
      {
        "command": "canopy.newVerifyFile",
        "title": "New Verify File",
        "category": "Canopy"
      },
      {
        "command": "canopy.newTemplate",
        "title": "New Template",
        "category": "Canopy"
      },
      {
        "command": "canopy.newConstantsFile",
        "title": "New Constants File",
        "category": "Canopy"
      },
      {
        "command": "canopy.newPolicyFile",
        "title": "New Policy File",
        "category": "Canopy"
      },
      {
        "command": "canopy.newCommandsFile",
        "title": "New Commands File",
        "category": "Canopy"
      },
      {
        "command": "canopy.newSchema",
        "title": "New Schema",
        "category": "Canopy"
      },
      {
        "command": "canopy.agentCreate",
        "title": "Create Skill",
        "category": "Canopy Agent"
      },
      {
        "command": "canopy.agentModify",
        "title": "Modify Skill",
        "category": "Canopy Agent"
      },
      {
        "command": "canopy.agentScaffold",
        "title": "Scaffold Skill",
        "category": "Canopy Agent"
      },
      {
        "command": "canopy.agentConvertToCanopy",
        "title": "Convert to Canopy",
        "category": "Canopy Agent"
      },
      {
        "command": "canopy.agentValidate",
        "title": "Validate Skill",
        "category": "Canopy Agent"
      },
      {
        "command": "canopy.agentImprove",
        "title": "Improve Skill",
        "category": "Canopy Agent"
      },
      {
        "command": "canopy.agentAdvise",
        "title": "Advise",
        "category": "Canopy Agent"
      },
      {
        "command": "canopy.agentRefactorSkills",
        "title": "Refactor Skills",
        "category": "Canopy Agent"
      },
      {
        "command": "canopy.agentConvertToRegular",
        "title": "Convert to Regular Skill",
        "category": "Canopy Agent"
      },
      {
        "command": "canopy.agentHelp",
        "title": "Help",
        "category": "Canopy Agent"
      }
    ],
    "configuration": {
      "title": "Canopy Skills",
      "properties": {
        "canopy.frameworkUrl": {
          "type": "string",
          "default": "https://github.com/kostiantyn-matsebora/claude-canopy",
          "description": "Git URL of the Canopy framework repository. Used by the 'Add as submodule' and 'Add as copy' commands."
        },
        "canopy.validate.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time validation of skill.md and ops.md files."
        },
        "canopy.validate.unknownOps": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "hint",
            "none"
          ],
          "default": "warning",
          "description": "Severity for ALL_CAPS op names not found in any ops registry."
        },
        "canopy.validate.opConformance": {
          "type": "boolean",
          "default": true,
          "description": "Show hints when a tree node's << / >> usage doesn't match the op's declared signature."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "sync-canopy-version": "node scripts/sync-canopy-version.js",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "icon": "node scripts/generate-icon.js",
    "package": "npx @vscode/vsce package",
    "test": "vitest run"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
