{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Canopy Template",
  "scopeName": "text.canopy-template",
  "fileTypes": [],
  "patterns": [
    { "include": "#placeholder" },
    { "include": "#optional-placeholder" },
    { "include": "#heading1" },
    { "include": "#heading2" },
    { "include": "#heading3" },
    { "include": "#bold" },
    { "include": "#italic" },
    { "include": "#code-inline" },
    { "include": "#yaml-key" }
  ],
  "repository": {
    "placeholder": {
      "comment": "<token> — will be substituted from step context",
      "match": "<([a-z][a-z0-9_-]*)>",
      "name": "variable.parameter.placeholder.canopy",
      "captures": {
        "1": { "name": "variable.parameter.placeholder.canopy" }
      }
    },
    "optional-placeholder": {
      "comment": "[optional-token] — optional substitution",
      "match": "\\[([a-z][a-z0-9_-]*)\\]",
      "name": "variable.parameter.optional.canopy",
      "captures": {
        "1": { "name": "variable.parameter.optional.canopy" }
      }
    },
    "heading1": {
      "match": "^(#)\\s+(.+)$",
      "captures": {
        "1": { "name": "punctuation.definition.heading.canopy" },
        "2": { "name": "markup.heading.1.canopy entity.name.section.canopy" }
      }
    },
    "heading2": {
      "match": "^(##)\\s+(.+)$",
      "captures": {
        "1": { "name": "punctuation.definition.heading.canopy" },
        "2": { "name": "markup.heading.2.canopy" }
      }
    },
    "heading3": {
      "match": "^(###)\\s+(.+)$",
      "captures": {
        "1": { "name": "punctuation.definition.heading.canopy" },
        "2": { "name": "markup.heading.3.canopy" }
      }
    },
    "bold": {
      "match": "(\\*\\*|__)(.+?)(\\*\\*|__)",
      "captures": {
        "2": { "name": "markup.bold.canopy" }
      }
    },
    "italic": {
      "match": "(?<!\\*)\\*(?!\\*)(.+?)(?<!\\*)\\*(?!\\*)",
      "captures": {
        "1": { "name": "markup.italic.canopy" }
      }
    },
    "code-inline": {
      "match": "`([^`]+)`",
      "captures": {
        "1": { "name": "markup.inline.raw.canopy" }
      }
    },
    "yaml-key": {
      "comment": "YAML key: value pairs at the root level",
      "match": "^([a-z][a-zA-Z0-9_-]*)(:)(?=\\s|$)",
      "captures": {
        "1": { "name": "entity.name.tag.yaml.canopy" },
        "2": { "name": "punctuation.separator.key-value.canopy" }
      }
    }
  }
}
