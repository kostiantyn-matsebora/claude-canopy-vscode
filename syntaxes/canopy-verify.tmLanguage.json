{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Canopy Verify",
  "scopeName": "text.canopy-verify",
  "fileTypes": [],
  "patterns": [
    { "include": "#checked-item" },
    { "include": "#unchecked-item" },
    { "include": "#heading1" },
    { "include": "#heading2" },
    { "include": "#placeholder-in-item" },
    { "include": "#bold" },
    { "include": "#code-inline" }
  ],
  "repository": {
    "unchecked-item": {
      "comment": "- [ ] item — an outstanding expected-state check",
      "match": "^(\\s*-\\s+)(\\[ \\])(\\s+)(.+)$",
      "captures": {
        "2": { "name": "keyword.operator.checkbox.unchecked.canopy" },
        "4": { "name": "string.unquoted.item.canopy" }
      }
    },
    "checked-item": {
      "comment": "- [x] item — a satisfied check",
      "match": "^(\\s*-\\s+)(\\[x\\])(\\s+)(.+)$",
      "captures": {
        "2": { "name": "markup.inserted.checkbox.checked.canopy" },
        "4": { "name": "comment.line.checked.canopy" }
      }
    },
    "placeholder-in-item": {
      "comment": "<token> placeholders inside verify items — these must be absent after skill runs",
      "match": "<([a-z][a-z0-9_-]*)>",
      "name": "variable.parameter.placeholder.canopy"
    },
    "heading1": {
      "match": "^(#)\\s+(.+)$",
      "captures": {
        "1": { "name": "punctuation.definition.heading.canopy" },
        "2": { "name": "markup.heading.1.canopy entity.name.section.canopy" }
      }
    },
    "heading2": {
      "match": "^(##)\\s+(.+)$",
      "captures": {
        "1": { "name": "punctuation.definition.heading.canopy" },
        "2": { "name": "markup.heading.2.canopy" }
      }
    },
    "bold": {
      "match": "(\\*\\*|__)(.+?)(\\*\\*|__)",
      "captures": {
        "2": { "name": "markup.bold.canopy" }
      }
    },
    "code-inline": {
      "match": "`([^`]+)`",
      "captures": {
        "1": { "name": "markup.inline.raw.canopy" }
      }
    }
  }
}
